#!/usr/bin/env python3
# cleanup - Automated cleanup script using dirscan

import getopt
import logging as l
import os
import random
import re
import subprocess
import sys
from datetime import *
from fcntl import LOCK_EX, LOCK_SH, LOCK_UN, flock
from os.path import *
from stat import *

from dirscan import *


def scan(**kwargs):
    try:
        DirScanner(**kwargs).scanEntries()
    except (InvalidArgumentException, PermissionError) as e:
        l.warning(f"Skipping {kwargs.get('directory', '?')}: {e}")


args = None
debug = False
status = False
opts = {"dryrun": False, "ages": False}

_lockpath = join(os.environ.get("TMPDIR", "/tmp"), "cleanup.lock")
lockfile = open(_lockpath, "wb")
flock(lockfile, LOCK_EX)

if len(sys.argv) > 1:
    options, args = getopt(sys.argv[1:], "nvuA", {})

    for o, a in options:
        if o in ("-v"):
            debug = True
            l.basicConfig(level=l.DEBUG, format="[%(levelname)s] %(message)s")
        elif o in ("-u"):
            status = True
            l.basicConfig(level=l.INFO, format="%(message)s")
        elif o in ("-n"):
            opts["dryrun"] = True
        elif o in ("-A"):
            opts["ages"] = True

if not args or "trash" in args:
    scan(
        directory="/Users/johnw/.Trash",
        days=28,
        mtime=True,
        cacheAttrs=True,
        maxSize="1%",
        sudo=True,
        depth=0,
        minimalScan=True,
        onEntryPastLimit=safeRemove,
        **opts,
    )

    if isdir("/.Trashes/501"):
        scan(
            directory="/.Trashes/501",
            days=28,
            mtime=True,
            cacheAttrs=True,
            maxSize="1%",
            sudo=True,
            depth=0,
            minimalScan=True,
            onEntryPastLimit=safeRemove,
            **opts,
        )

    if isdir("/Users/johnw/Library/Mobile Documents/.Trash"):
        scan(
            directory="/Users/johnw/Library/Mobile Documents/.Trash",
            days=28,
            mtime=True,
            cacheAttrs=True,
            maxSize="1%",
            sudo=True,
            depth=0,
            minimalScan=True,
            onEntryPastLimit=safeRemove,
            **opts,
        )

    for name in os.listdir("/Volumes"):
        path = join("/Volumes", name, ".Trashes", "501")
        if exists(path):
            scan(
                directory=path,
                days=28,
                mtime=True,
                cacheAttrs=True,
                maxSize="2%",
                sudo=True,
                depth=0,
                minimalScan=True,
                onEntryPastLimit=safeRemove,
                **opts,
            )

    if isdir("/Volumes/tank"):
        for name in os.listdir("/Volumes/tank"):
            path = join("/Volumes", "tank", name, ".Trashes", "501")
            if exists(path):
                scan(
                    directory=path,
                    days=28,
                    mtime=True,
                    cacheAttrs=True,
                    maxSize="2%",
                    sudo=True,
                    depth=0,
                    minimalScan=True,
                    onEntryPastLimit=safeRemove,
                    **opts,
                )

if not args or "backups" in args:
    if exists("/Users/johnw/.cache/emacs/backups"):
        scan(
            directory="/Users/johnw/.cache/emacs/backups",
            days=28,
            mtime=True,
            sudo=True,
            depth=0,
            maxSize="10000000000",
            minimalScan=True,
            onEntryPastLimit=safeRemove,
            **opts,
        )

    if exists("/Users/johnw/.cache/iTerm2/logs"):
        scan(
            directory="/Users/johnw/.cache/iTerm2/logs",
            days=28,
            mtime=True,
            sudo=True,
            depth=0,
            maxSize="10000000000",
            minimalScan=True,
            onEntryPastLimit=safeRemove,
            **opts,
        )

    for name in os.listdir("/Volumes"):
        path = join("/Volumes", name, ".backups")
        if exists(path):
            scan(
                directory=path,
                days=28,
                mtime=True,
                sudo=True,
                depth=0,
                maxSize="10000000000",
                minimalScan=True,
                onEntryPastLimit=safeRemove,
                **opts,
            )

flock(lockfile, LOCK_UN)
os.remove(_lockpath)

sys.exit(0)

# cleanup.py ends here
